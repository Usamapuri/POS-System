# ───────────────────────────────────────────────────────────────────────────
# Backend env vars — copy to backend/.env for local dev, or paste into the
# Railway service's Variables tab for each restaurant. Every restaurant gets
# its own DATABASE_URL and its own JWT_SECRET; everything else is identical
# across deployments.
# ───────────────────────────────────────────────────────────────────────────

# ── REQUIRED in production (GIN_MODE=release) ──────────────────────────────

# Postgres connection string. On Railway use the reference variable:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Locally, docker-compose.dev.yml provides this via the discrete DB_* vars
# below — leave DATABASE_URL unset to fall back to those.
DATABASE_URL=

# JWT signing secret. MUST be unique per restaurant — re-using it lets a
# token issued by one restaurant validate against another.
# Generate with: openssl rand -base64 48
# When GIN_MODE=release and this is unset, the backend refuses to boot.
JWT_SECRET=

# Comma-separated list of public frontend origins allowed by CORS. Include
# every URL the browser can use to reach this restaurant's frontend (custom
# domain + Railway's *.up.railway.app fallback if you keep it).
#   Example: CORS_ORIGINS=https://cova.bhookly.com,https://pos-cova.up.railway.app
CORS_ORIGINS=https://your-restaurant.bhookly.com

# Gin run mode. Use 'release' in production — it disables debug logging AND
# turns on the JWT_SECRET fail-fast guard above.
GIN_MODE=release

# ── OPTIONAL ───────────────────────────────────────────────────────────────

# HTTP listen port. Railway injects this automatically; only set explicitly
# for local dev or non-Railway deployments.
PORT=8080

# IANA timezone used for all date bucketing (daily reports, business-day
# windows, PRA invoice late-print window). Defaults to Asia/Karachi when
# unset, but explicit > implicit.
BUSINESS_TIMEZONE=Asia/Karachi

# ── LEGACY: discrete DB_* fallback (use ONLY if DATABASE_URL is unset) ─────
# Kept for local docker-compose compatibility. New deployments should set
# DATABASE_URL above and leave these unset.
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres123
# DB_NAME=pos_system
# DB_SSLMODE=disable
