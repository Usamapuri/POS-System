# Development Dockerfile for React frontend

FROM node:18-alpine AS development

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including devDependencies)
RUN npm ci

# Copy source code (includes docker-dev-entrypoint.sh)
COPY . .

RUN if [ -f docker-dev-entrypoint.sh ]; then sed -i 's/\r$//' docker-dev-entrypoint.sh && chmod +x docker-dev-entrypoint.sh; fi

# Expose port 3000 and Vite HMR port
EXPOSE 3000 5173

# Invoke via sh so a CRLF copy of the script from a Windows bind mount does not break the shebang.
# Ensure deps exist in the bind-mount + node_modules volume setup (see docker-compose.dev.yml)
ENTRYPOINT ["/bin/sh", "/app/docker-dev-entrypoint.sh"]
CMD ["npm", "run", "dev"]

# Production build stage (same as regular Dockerfile)
FROM node:18-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY . .
RUN npm run build

FROM nginx:alpine AS production
COPY nginx.conf /etc/nginx/nginx.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:3000 || exit 1
CMD ["nginx", "-g", "daemon off;"]

