# ───────────────────────────────────────────────────────────────────────────
# Frontend env vars — copy to frontend/.env for local dev, or paste into the
# Railway service's Variables tab for each restaurant.
#
# IMPORTANT: VITE_API_URL is hardcoded to /api/v1 in the production build
# (frontend/Dockerfile RUN VITE_API_URL=/api/v1 npm run build), so the
# browser always calls same-origin and nginx proxies to BACKEND_URL. You
# do NOT need to set VITE_API_URL on Railway.
# ───────────────────────────────────────────────────────────────────────────

# nginx proxy target. ALWAYS use Railway's private domain via reference
# variable rather than the public *.up.railway.app URL — public URLs route
# through Railway's edge (egress charges, ~50-200ms extra latency).
#   Example: BACKEND_URL=http://${{COVA-BackEnd.RAILWAY_PRIVATE_DOMAIN}}:8080
# Locally (docker-compose.dev.yml) the default points at the backend service
# on the compose network: http://backend:8080
BACKEND_URL=http://${{Backend.RAILWAY_PRIVATE_DOMAIN}}:8080

# nginx listen port. Railway sometimes overrides to 8080; either value works.
PORT=3000

# ── DEV-ONLY ───────────────────────────────────────────────────────────────
# Where the Vite dev server fetches the API from. Production builds ignore
# this (the URL is baked in via the Dockerfile build arg above).
# VITE_API_URL=http://localhost:8080/api/v1
